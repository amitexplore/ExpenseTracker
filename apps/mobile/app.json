{
  "expo": {
    "name": "ExpenseTracker",
    "slug": "expense-tracker",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.amitexplore.expensetracker",
      "infoPlist": {
        "NSUserNotificationUsageDescription": "We send notifications when new expenses are detected.",
        "BGTaskSchedulerPermittedIdentifiers": ["com.amitexplore.expensetracker.gmailsync"]
      }
    },
    "android": {
      "package": "com.amitexplore.expensetracker",
      "permissions": ["RECEIVE_BOOT_COMPLETED"]
    },
    "plugins": [
      "expo-router",
      "expo-background-fetch"
    ],
    "scheme": "expensetracker",
    "extra": {
      "eas": { "projectId": "your-eas-project-id" }
    }
  }
}
